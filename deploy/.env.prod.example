# HFI production environment template (VM-local only).
# Copy to /opt/hfi/app/.env.prod and fill real values.
# Keep permissions strict: chmod 600 .env.prod

# Runtime mode and build metadata
ENVIRONMENT=production
APP_VERSION=manual-local

# API auth
DASHBOARD_PASSWORD=replace-with-a-strong-password
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# OpenAI
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5-nano
OPENAI_TEMPERATURE=0.1

# Telegram bot
TELEGRAM_BOT_TOKEN=123456789:replace-me
TELEGRAM_CHAT_ID=123456789
BRIEF_TIMES=08:00,19:00
ALERT_CHECK_INTERVAL_MINUTES=15

# URLs / ingress
# API_BASE_URL is internal because the bot runs in the same Docker network.
API_BASE_URL=http://api:8000
# FRONTEND_BASE_URL and CORS_ORIGINS must be your Tailscale HTTPS URL.
FRONTEND_BASE_URL=https://hfi-prod.tailnet-xyz.ts.net
CORS_ORIGINS=https://hfi-prod.tailnet-xyz.ts.net
# Frontend talks to API through reverse proxy path.
NEXT_PUBLIC_API_URL=/api
# Keep redirect disabled because API is reached internally over HTTP from proxy/bot.
API_ENFORCE_HTTPS_REDIRECT=false

# Data volume path on the VM host
HOST_DATA_DIR=/opt/hfi/data

# Scraper credentials (manual runs only in v1)
X_USERNAME=your_email@example.com
X_PASSWORD=your_password
SCRAPER_HEADLESS=true
SCRAPER_MAX_TRENDS=5
SCRAPER_TWEETS_PER_TREND=3

# Processor runtime
PROCESSOR_POLL_INTERVAL=30
LOG_LEVEL=INFO

# Backups (optional Azure Blob upload)
BACKUP_RETENTION_DAYS=30
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_SAS_TOKEN=
AZURE_BLOB_RETENTION_DAYS=30
