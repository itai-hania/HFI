# Hebrew FinTech Informant (HFI) - Environment Variables Template
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control

# ============================================================================
# X (Twitter) Credentials
# ============================================================================
# Use a burner account for scraping to avoid main account suspension
# Get credentials from: https://twitter.com/
X_USERNAME=your_email@example.com
X_PASSWORD=your_password_here

# ============================================================================
# OpenAI API Configuration
# ============================================================================
# Required for GPT-4o translation and content generation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model configuration
OPENAI_MODEL=gpt-5-nano
OPENAI_TEMPERATURE=0.1

# ============================================================================
# Database Configuration
# ============================================================================
# SQLite database path (shared volume in containers)
# For Docker/K8s: Use /app/data/hfi.db
# For local dev: Use ./data/hfi.db
DATABASE_URL=sqlite:////app/data/hfi.db

# ============================================================================
# Redis Configuration (Optional)
# ============================================================================
# Redis for caching and rate limiting
# For Docker Compose: redis://redis:6379/0
# For K8s: redis://hfi-redis:6379/0
# For local: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ============================================================================
# Application Configuration
# ============================================================================
# Logging
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development

# ============================================================================
# API / Auth
# ============================================================================
# Shared password used to mint JWT access tokens via /api/auth/login
DASHBOARD_PASSWORD=change-this-password

# 32+ character secret for JWT signing (required in production)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# API URL (used by Telegram bot / local clients)
API_BASE_URL=http://localhost:8000

# Frontend URL used by Telegram draft links
FRONTEND_BASE_URL=http://localhost:3000

# Next.js frontend API target
# For local worktree setups, keep the actual frontend value in frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# Telegram Bot (optional)
# ============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BRIEF_TIMES=08:00,19:00
ALERT_CHECK_INTERVAL_MINUTES=15
